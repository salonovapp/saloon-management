APP_NAME="Saloon Management"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_FORWARD_PORT=3306
DB_DATABASE=saloon_db
DB_USERNAME=saloon_user
DB_PASSWORD=saloon_password

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

REDIS_HOST=redis
REDIS_PASSWORD=redis_password
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

NGINX_PORT=80
NGINX_SSL_PORT=443
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
PHPMYADMIN_PORT=8080
RUN_MIGRATIONS=true

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

OTP_CODE_EXPIRY_MINUTES=10
OTP_ALLOW_DEVELOPMENT_MASTER_CODE=true
OTP_DEVELOPMENT_MASTER_CODE=0101
OTP_EXPOSE_CODE_IN_RESPONSE=true
OTP_EMAIL_DRIVER=log
OTP_SMS_DRIVER=log
